# Plantilla de variables de entorno para PRODUCCION.
# Copiar a .env.production en la EC2 y completar con valores reales.
# NO commitear .env.production al repo.

# ===== Base de datos PostgreSQL =====
# Si Postgres corre en el mismo compose: DB_HOST=postgres
# Si se usa RDS: DB_HOST=stocksense-prod.xxxx.us-east-1.rds.amazonaws.com
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=stocksense_prod
# Generar con: openssl rand -base64 32
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_32_CHARS
DB_NAME=stocksense_prod

# ===== MongoDB =====
# Si Mongo corre en el mismo compose:
#   MONGO_USERNAME / MONGO_PASSWORD se usan para inicializar el contenedor;
#   MONGO_URI debe usar esas mismas credenciales.
# Si se usa Atlas Free Tier:
#   MONGO_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/stocksense?retryWrites=true&w=majority
#   (en ese caso MONGO_USERNAME / MONGO_PASSWORD / MONGO_DATABASE se ignoran al no haber service mongo).
MONGO_USERNAME=stocksense_prod
MONGO_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_MONGO
MONGO_DATABASE=stocksense_analytics
MONGO_URI=mongodb://stocksense_prod:CAMBIAR_POR_PASSWORD_SEGURO_MONGO@mongo:27017/stocksense_analytics?authSource=admin

# ===== JWT =====
# OBLIGATORIO cambiar. Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_SECRET_SEGURO_MIN_64_CHARS_RANDOM
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===== Groq (IA) =====
# Sin esta key, los endpoints de /ai responden 503 ServiceUnavailable.
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.3

# ===== App =====
PORT=3000
NODE_ENV=production

# ===== CORS =====
# URL del frontend en Vercel (usar el dominio definitivo, no la URL preview).
FRONTEND_URL=https://stocksense.vercel.app
