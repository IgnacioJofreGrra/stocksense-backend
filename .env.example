# ===== Base de datos PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=stocksense
DB_PASSWORD=cambiar_en_local
DB_NAME=stocksense

# ===== MongoDB (analitica) =====
MONGO_USERNAME=stocksense
MONGO_PASSWORD=cambiar_en_local
MONGO_DATABASE=stocksense_analytics
MONGO_URI=mongodb://stocksense:cambiar_en_local@localhost:27017/stocksense_analytics?authSource=admin

# ===== JWT =====
# Minimo 32 caracteres. Generar uno aleatorio en produccion.
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres-xxx
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===== App =====
PORT=3000
NODE_ENV=development

# ===== CORS =====
# URL del frontend en produccion (Vercel). En dev queda vacio: localhost:5173 y :3000 ya estan permitidos.
FRONTEND_URL=https://stocksense.vercel.app

# ===== pgAdmin =====
PGADMIN_EMAIL=admin@stocksense.dev
PGADMIN_PASSWORD=cambiar_en_local

# ===== IA (Groq) =====
# Obtener API key gratuita en https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
# Bajo = mas deterministico/factual; subir a 0.7+ para respuestas creativas.
GROQ_TEMPERATURE=0.3
